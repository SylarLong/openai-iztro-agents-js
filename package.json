{
  "name": "openai-iztro-agents",
  "version": "0.1.0",
  "description": "Build your own Ziwei (Purple Star Astrology) agent on the OpenAI Agents SDK — hosted brain + iztro, with your own local tools, MCP, and human-in-the-loop.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "ziwei",
    "astrology",
    "purple-star",
    "iztro",
    "openai-agents",
    "agents",
    "llm"
  ],
  "author": "iztro",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/SylarLong/openai-iztro-agents-js.git"
  },
  "homepage": "https://github.com/SylarLong/openai-iztro-agents-js#readme",
  "dependencies": {
    "@openai/agents": "^0.12.0",
    "openai": "^6.45.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
